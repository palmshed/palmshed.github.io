# Vercel Postgres
DATABASE_URL=postgres://user:pass@host:5432/db

# Public base URL, used in reset emails
PUBLIC_BASE_URL=https://palmshed.github.io

# hCaptcha (public site key is fetched at runtime via /api/config)
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
CAPTCHA_SECRET=your-hcaptcha-secret
CAPTCHA_PROVIDER=hcaptcha   # hcaptcha | turnstile

# Resend (transactional email for password reset)
RESEND_API_KEY=re_xxx
RESEND_FROM=auth@palmshed.io
# RESEND_DISABLED=true   # log reset links instead of sending (local dev)

# Set to true to skip captcha verification in local dev
# CAPTCHA_DISABLED=true
